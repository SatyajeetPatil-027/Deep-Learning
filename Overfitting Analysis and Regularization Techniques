    Flatten(input_shape=(28, 28)),
    Dense(128, activation='relu',input_shape=784,kernel_regularizer=l2(0.001)),
    Dropout(0.5),
    BatchNormalization(),
    Dense(64, activation='relu',input_shape=512,kernel_regularizer=l2(0.001)),
